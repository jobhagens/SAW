from abc import ABC, abstractmethod
import matplotlib.pyplot as plt #al dit een error geeft ff in je terminal 'pip install matplotlib'


class Lattice(ABC):  # kind of the blueprint
    def __init__(self, size: int, dimension: int, neighbors: int):
        self.size = size
        self.dimension = dimension
        self.num_neighbors = neighbors

    @abstractmethod
    def get_neighbors(self, position: tuple) -> list[
        tuple]:  # Return all possible neighbor positions from current position.
        pass

    @abstractmethod
    def get_possible_steps(self) -> list[tuple]:  # Return all valid step vectors
        pass

    def is_valid_position(self, position: tuple) -> bool:  # set True as basis and change once we implement bounds
        return True  # start with boundless


class Square_Lattice(Lattice):
    def __init__(self, size: int):
        super().__init__(size, dimension=2, neighbors=4)
        self.possible_steps = [
            (1, 0),
            (-1, 0),
            (0, 1),
            (0, -1)
        ]
        full_square = math.floor(math.sqrt(size))
        # extra_cells = size - full_square ** 2
        self.width = self.height = full_square
        # self.extra_top = full_square * (full_square<=extra_cells) + extra_cells* (full_square>extra_cells)
        # self.extra_side = extra_cells - self.extra_top


    def get_possible_steps(self):
        return self.possible_steps

    def in_bounds(self, position: tuple):
        x, y = position
        if 0 <= x <= self.width and 0 <= y <= self.height:
            return True
        else:
            return False

    def get_neighbors(self, position: tuple):
        x, y = position
        return [(x + dx, y + dy) for dx, dy in self.possible_steps if
                self.in_bounds((x + dx, y + dy))]  # vanaf if check of het in de grid zit

    def visualise(self, walk: list[tuple], debug: set[tuple]):
        x = [x[0] for x in walk]
        y = [y[1] for y in walk]
        plt.xlim(-0.25, self.width+0.25)
        plt.ylim(-0.25, self.width+0.25)
        plt.plot(x, y, color = 'red')
        plt.grid(which = 'both', alpha = 0.5)
        x2 = [x[0] for x in debug]
        y2 = [y[1] for y in debug]
        plt.scatter(x2, y2, color = 'blue')
        plt.show()

