class Self_Avoiding_Walk:
    def __init__(self, lattice: Lattice, origin:tuple):
        self.lattice = lattice  # kies de latice die je wil
        self.origin = origin
        self.path: list[tuple] = [] #houd bij wat het pad is
        self.visited: set = set() #eigenlijk weer het pad, maar dan allen de unieke waardes in set omdat O(1)
        self.reset(origin)

    def reset(self, new_start:tuple):
        self.origin = new_start
        self.path = [new_start]
        self.visited = {new_start}

    def step(self):
        current = self.path[-1]
        neighbors = self.lattice.get_neighbors(current)
        free_nodes = [node for node in neighbors if node not in self.visited]
        if not free_nodes: #end walk if no possible nodes (and use for backtracking later)
            return False

        chosen = random.choice(free_nodes)
        self.path.append(chosen)
        self.visited.add(chosen)
        return True

    def walk(self, max_steps: int):#the running itself for N steps
        self.reset(self.origin)
        for steps in range(max_steps):
            if not self.step():
                break #of later backtrack
        return self.path
