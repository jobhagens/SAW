class Lattice(ABC):  # kind of the blueprint
    def __init__(self, size: int, dimension: int, neighbors: int):
        self.size = size
        self.dimension = dimension
        self.num_neighbors = neighbors

    @abstractmethod
    def get_neighbors(self, position: tuple, parity:bool) -> list[
        tuple]:  # Return all possible neighbor positions from current position.
        pass

    @abstractmethod
    def get_possible_steps(self) -> list[tuple]:  # Return all valid step vectors
        pass


class Square_Lattice(Lattice):
    def __init__(self, size: int, neighbors: int):
        super().__init__(size, dimension=int(neighbors/2), neighbors=neighbors)
        self.possible_steps = []
        for i in range(self.dimension):
            for val in [1, -1]:
                step = [0] * self.dimension
                step[i] = val
                self.possible_steps.append(tuple(step))

        full_square = math.floor(size**(1/self.dimension))
        # extra_cells = size - full_square ** 2
        self.bounds = [full_square] * self.dimension
        # self.extra_top = full_square * (full_square<=extra_cells) + extra_cells* (full_square>extra_cells)
        # self.extra_side = extra_cells - self.extra_top

    def get_possible_steps(self):
        return self.possible_steps

    def in_bounds(self, position: tuple):
        for i in range (self.dimension):
            if 0 > position[i] or self.bounds[i] < position[i]:
                return False
        return True

    def get_neighbors(self, position: tuple, parity:bool = None):
        all_neighbors = []
        for option in self.possible_steps: #voor elke mogelijke stap moet er een neighbor worden gereturned
            step = [] #nodig om 1 neighbor te maken omdat optellen van tuples niet handig gaat
            for i in range(self.dimension): #elk i'de element van de positie en de stap bij elkaar optellen
                step.append(position[i]+option[i])
            step = tuple(step) #nodig om goed te werken met andere functies
            if self.in_bounds(step):
                all_neighbors.append(step)
        return all_neighbors

    def visualise_R2(self, walk: list[tuple]):
        x = [p[0] for p in walk]#split tuples up zodat we het kunnen plotten
        y = [p[1] for p in walk]
        plt.plot(x, y, color='red')  # de walk maken

        x_bound = self.bounds[0]
        y_bound = self.bounds[1]
        plt.xlim(-0.25, x_bound+0.25)#grid maken tot alle mogelijke waardes van x en y
        plt.ylim(-0.25, y_bound+0.25)

        plt.xticks(range(x_bound+1))#zorgen dat op elke integer een gridlijn staat
        plt.yticks(range(y_bound+1))
        plt.grid(which = "both", alpha = 0.5)

        plt.show()

    def visualise_R3(self, walk: list[tuple]):
        x = [p[0] for p in walk]
        y = [p[1] for p in walk]
        z = [p[2] for p in walk]

        fig = plt.figure() #canvas maken
        ax = fig.add_subplot(111, projection='3d') #subplot toevoegen van 1 rij en 1 kolom
        ax.plot(x, y,z, color='red', linewidth = 1.5, alpha = 0.2)  #(dikke en transparante) walk maken

        x_bound = self.bounds[0]
        y_bound = self.bounds[1]
        z_bound = self.bounds[2]
        ax.set_xlim(-0.25, x_bound+0.25)#grid maken tot alle mogelijke waardes van x en y
        ax.set_ylim(-0.25, y_bound+0.25)
        ax.set_zlim(-0.25, z_bound + 0.25)

        ax.set_xticks(range(x_bound+1))#zorgen dat op elke integer een gridlijn staat
        ax.set_yticks(range(y_bound+1))
        ax.set_zticks(range(z_bound + 1))
        ax.grid(which = "both", alpha = 0.25) #in 3d waren ze veel prominenter dus maak ze minder licht

        plt.show()

class Honeycomb(Lattice):
    def __init__(self, size: int):
        super().__init__(size, dimension=3, neighbors=3)
        self.possible_steps = []
        for i in range(self.dimension):
            for val in [1, -1]:
                step = [0] * self.dimension
                step[i] = val
                self.possible_steps.append(tuple(step))

        self.layers = math.floor((3 + math.sqrt(9 - 12 * (1 - size))) / 6)
        extra_cells = size - (3 * self.layers ** 2 - 3 * self.layers + 1)

    def get_possible_steps(self):
        return self.possible_steps

    def in_bounds(self, position: tuple):
        for i in range(self.dimension):
            if 1-self.layers > position[i] or self.layers < position[i]: #als je origin als (0,0,0) ziet dan kan het max 1-anatal lagen stappen naar links(-onder) of rechtsonder
                return False
        return True

    def get_neighbors(self, position: tuple, parity: bool) -> list[tuple]:
        all_neighbors = []
        for i in range(3): #3 mogelijke stappen
            match i:   #verschilende parities hebben verschillende opties (op parity = False [(1,0,0), (0,-1,0), (0,0,1)])
                case 0:
                    index = parity
                case 1:
                    index = 3-parity
                case 2:
                    index = 4 + parity
            option = self.possible_steps[index]
            step = []  # nodig om 1 neighbor te maken omdat optellen van tuples niet handig gaat
            for j in range(self.dimension):  # elk j'de element van de positie en de stap bij elkaar optellen
                step.append(position[j] + option[j])
            step = tuple(step)
            if self.in_bounds(step): #als de optie in de grenzen zit, dan toevoegen
                all_neighbors.append(step)
        return all_neighbors


class Self_Avoiding_Walk:
    def __init__(self, lattice: Lattice, origin: tuple):
        self.lattice = lattice  # attach walk to lattice
        self.origin = origin
        self.path: list[tuple] = []  # keep track of the path
        self.visited: set = set()  # used to store visited nodes
        self.reset(origin)
        self.temp_unavailable: set = set()
        self.parity = False #nodig voor honeycomb om te bepalen op wat voor type node je staat

    def reset(self, new_start: tuple):
        self.origin = new_start
        self.path = [new_start]
        self.visited = {new_start}

    def walk(self, max_steps: int):
        # guard clause to check if desired length of walk is reached
        # note: N + 1 because origin is included in path
        if len(self.path) == max_steps + 1:
            return True

        current = self.path[-1]
        neighbors_options = [node for node in self.lattice.get_neighbors(current, self.parity) if node not in self.visited]

        # create randomness in neighbour choosing, but allow for iterative structure for the recursive backtracking
        random.shuffle(neighbors_options)

        for chosen_neighbor in neighbors_options: #alle opties doorlopen voor als je vastloopt op 1 optie en je moet backtracken
            self.path.append(chosen_neighbor)
            self.visited.add(chosen_neighbor)
            self.parity = not self.parity #switch de parity als je een stap vooruit doet

            if self.walk(max_steps): #een stap vooruit nemen als het kan en anders laatste element weghalen en vanaf het laatste 'keuzepunt' de volgende optie nemen
                return True

            self.visited.remove(chosen_neighbor)
            self.path.pop()
            self.parity = not self.parity  # switch de parity als je een stap achteruit doet

        return False

    def generate(self, max_steps: int):  # the running itself for N steps
        self.reset(self.origin)
        if self.walk(max_steps):
            return self.path
        return [self.origin]# return simply a path containing only the origin if no path is found

