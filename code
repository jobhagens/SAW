import matplotlib.pyplot as plt


class Lattice(ABC):
    def __init__(self, size: int, dimension: int, neighbors: int):
        self.size = size
        self.dimension = dimension
        self.num_neighbors = neighbors

    @abstractmethod
    def get_neighbors(self, position: tuple, parity:bool) -> list[
        tuple]:  # Return all possible neighbor positions from current position.
        pass
    
    @abstractmethod
    def in_bounds(self, position: tuple):
        # handles boundary checking of the lattice
        pass


class Orthogonal_Lattice(Lattice):
    def __init__(self, size: int, neighbors: int):
        self.neighbors = neighbors - neighbors%2
        super().__init__(size, dimension=int(neighbors/2), neighbors=neighbors)
        self.possible_steps = []
        for i in range(self.dimension):
            for val in [1, -1]:
                step = [0] * self.dimension
                step[i] = val
                self.possible_steps.append(tuple(step))

        full_square = math.floor(size**(1/self.dimension))
        self.bounds = [full_square] * self.dimension


    def in_bounds(self, position: tuple):
        for i in range (self.dimension):
            if 0 > position[i] or self.bounds[i] < position[i]:
                return False
        return True

    def get_neighbors(self, position: tuple, parity:bool = False):
        all_neighbors = []

        #adding tuples does not correspond to adding them as vectors. The following code solves this issue
        for option in self.possible_steps:
            step = [] 
            for i in range(self.dimension): 
                step.append(position[i]+option[i])
            step = tuple(step) #convert list back to tuple
            if self.in_bounds(step):
                all_neighbors.append(step)
        return all_neighbors

    def visualise_R2(self, walk: list[tuple]):
        #split tuples to x and y coordinate lists
        x = [p[0] for p in walk]
        y = [p[1] for p in walk]
        
        plt.plot(x, y, color='red')
        x_bound = self.bounds[0]
        y_bound = self.bounds[1]

        #plotting grid
        plt.xlim(-0.25, x_bound+0.25)
        plt.ylim(-0.25, y_bound+0.25)

        #plotting grid lines
        plt.xticks(range(x_bound+1))
        plt.yticks(range(y_bound+1))
        plt.grid(which = "both", alpha = 0.5)

        plt.show()

    def visualise_R3(self, walk: list[tuple]):
        x = [p[0] for p in walk]
        y = [p[1] for p in walk]
        z = [p[2] for p in walk]
        
        #create canvas
        fig = plt.figure()
        ax = fig.add_subplot(111, projection='3d') #adds subplot of one row and column
        ax.plot(x, y,z, color='red', linewidth = 1.5, alpha = 0.2) 
    
        x_bound = self.bounds[0]
        y_bound = self.bounds[1]
        z_bound = self.bounds[2]

        #plotting grid
        ax.set_xlim(-0.25, x_bound + 0.25)
        ax.set_ylim(-0.25, y_bound + 0.25)
        ax.set_zlim(-0.25, z_bound + 0.25)
        #plotting grid lines
        ax.set_xticks(range(x_bound + 1))
        ax.set_yticks(range(y_bound + 1))
        ax.set_zticks(range(z_bound + 1))
        #adjust axis transparancy
        ax.grid(which = "both", alpha = 0.25) 

        plt.show()

class Honeycomb_Lattice(Lattice):
    def __init__(self, size: int):
        super().__init__(size, dimension=3, neighbors=3)
        self.possible_steps = []
        for i in range(self.dimension):
            for val in [1, -1]:
                step = [0] * self.dimension
                step[i] = val
                self.possible_steps.append(tuple(step))

        self.layers = math.floor((3 + math.sqrt(9 - 12 * (1 - size))) / 6)
        #extra_cells = size - (3 * self.layers ** 2 - 3 * self.layers + 1)

    def in_bounds(self, position: tuple):  # (0,0,0) is at the bottom left
        for i in range(self.dimension):
            if i == 2:
                if not (-(self.layers - 1) <= position[
                    i] <= self.layers):  # voor 3e basisvector is t raar omdat we linksonder starten kan die nog bede kanten op
                    return False
            else:
                if not (0 <= position[i] <= 2 * self.layers - 1):
                    return False
        return True

    def get_neighbors(self, position: tuple, parity: bool) -> list[tuple]:
        all_neighbors = []
        for i in range(self.dimension): #3 different moves
            match i:   #Different parities have different movesets (for example, parity = False => [(1,0,0), (0,-1,0), (0,0,1)])
                case 0:
                    index = parity
                case 1:
                    index = 3-parity
                case 2:
                    index = 4 + parity
            
            #adding tuples does not correspond to adding them as vectors. The following code solves this issue
            step = self.possible_steps[index]
            neighbor = []  
            for j in range(self.dimension): 
                neighbor.append(position[j] + step[j])
            step = tuple(step)

            #boundary check
            if self.in_bounds(neighbor): 
                all_neighbors.append(neighbor)
        return all_neighbors


class Self_Avoiding_Walk:
    def __init__(self, lattice: Lattice, origin: tuple):
        self.lattice = lattice  # attach walk to lattice
        self.origin = origin
        self.path: list[tuple] = []  # keep track of the path
        self.visited: set = set()  # used to store visited nodes
        self.reset(origin)
        self.temp_unavailable: set = set()
        self.parity = False #used in honeycomb structure

    def reset(self, new_start: tuple):
        self.origin = new_start
        self.path = [new_start]
        self.visited = {new_start}

    def walk(self, max_nodes: int):
        # guard clause to check if desired length of walk is reached
        # note: N + 1 because origin is included in path
        if len(self.path) == max_nodes:
            return True

        current = self.path[-1]
        neighbors_options = [node for node in self.lattice.get_neighbors(current, self.parity) if
                             node not in self.visited]

        # create randomness in neighbour choosing, but allow for iterative structure for the recursive backtracking
        random.shuffle(neighbors_options)

        for chosen_neighbor in neighbors_options:
            self.path.append(chosen_neighbor)
            self.visited.add(chosen_neighbor)
            self.parity = not self.parity  # switch parity, used for hexagonal lattice

            if self.walk(max_nodes):  # recursively call the backtracking walk method
                return True

            # remove last node from path, since self.walk(max_steps) didn't return true. Then start the process over again
            self.visited.remove(chosen_neighbor)
            self.path.pop()
            self.parity = not self.parity  # switch back the parity

        return False

    def generate(self, max_nodes: int):  # generate a random walk of length max_steps
        self.reset(self.origin)
        if self.walk(max_nodes = max_nodes):
            return self.path
        return [self.origin]  # return simply a path containing only the origin if no path is found. Avoids error messages

    def average_length(self, length_walk, iterations):
        total_distance = 0
        for i in range(iterations):
            end_point = self.generate(length_walk)[-1]
            total_distance += math.sqrt((end_point[0]-self.origin[0])**2+(end_point[1]-self.origin[1])**2)
        return round(total_distance/iterations, 2)
